---
layout: null
permalink: /search.json
---
[
  {% assign is_first = true %}
  {% assign posts = site.blog_articles | sort: 'order' | reverse %}
  {% for post in posts %}
    {% capture post_url %}{{ '/blog/' | relative_url }}#{{ post.slug }}{% endcapture %}
    {% unless is_first %},{% endunless %}
    {% assign is_first = false %}
    {
      "title": {{ post.title | jsonify }},
      "url": {{ post_url | jsonify }},
      "type": "Blog",
      "group": "article",
      "order": {{ post.order | default: 0 | plus: 0 | jsonify }},
      "content": {{ post.content | strip_html | strip_newlines | jsonify }}
    }
  {% endfor %}

  {% assign posts = site.thingies_articles | sort: 'order' | reverse %}
  {% for post in posts %}
    {% capture post_url %}{{ '/thingies/' | relative_url }}#{{ post.slug }}{% endcapture %}
    {% unless is_first %},{% endunless %}
    {% assign is_first = false %}
    {
      "title": {{ post.title | jsonify }},
      "url": {{ post_url | jsonify }},
      "type": "Thingies",
      "group": "article",
      "order": {{ post.order | default: 0 | plus: 0 | jsonify }},
      "content": {{ post.content | strip_html | strip_newlines | jsonify }}
    }
  {% endfor %}

  {% assign calendar_page = site.pages | where_exp: "item", "item.path == 'calendar/index.html'" | first %}
  {% if calendar_page and calendar_page.calendar_entries %}
    {% assign calendar_entries = calendar_page.calendar_entries | sort: 'date' | reverse %}
    {% for entry in calendar_entries %}
      {% assign entry_title = entry.title | default: 'Calendar note' %}
      {% assign entry_date = entry.date | date: "%Y-%m-%d" %}
      {% assign entry_year = entry.date | date: "%Y" %}
      {% capture calendar_url %}{{ '/calendar/' | relative_url }}#{{ entry_year }}{% endcapture %}
      {% capture calendar_content %}{{ entry_date }} {{ entry_title }} {{ entry.content }}{% endcapture %}
      {% unless is_first %},{% endunless %}
      {% assign is_first = false %}
      {
        "title": {{ entry_title | jsonify }},
        "url": {{ calendar_url | jsonify }},
        "type": "Calendar",
        "group": "calendar",
        "date": {{ entry_date | jsonify }},
        "content": {{ calendar_content | strip_html | strip_newlines | jsonify }}
      }
    {% endfor %}
  {% endif %}
]
